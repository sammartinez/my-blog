---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 – Page not found">
  <div class="container page">
    <p class="code">404</p>
    <h1>Page not found</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href={import.meta.env.BASE_URL} class="home-link">← Back to home</a>
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 5rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .code {
    font-family: var(--font-mono);
    font-size: 5rem;
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 1rem;
  }

  h1 { margin-bottom: 1rem; }

  p { color: var(--color-ink-muted); margin-bottom: 2rem; }

  .home-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
</style>
