---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<BaseLayout title="My Blog · Home" description="Welcome to my blog.">
  <section class="hero container">
    <div class="hero-content">
      <p class="hero-eyebrow">Welcome</p>
      <h1 class="hero-headline">
        Thoughts, ideas,<br />
        and&thinsp;<em>things I learn</em>.
      </h1>
      <p class="hero-sub">
        A personal blog about web development, design, and whatever else catches my attention.
        Written by a curious human.
      </p>
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn-primary">Read the blog →</a>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="recent-posts container">
      <div class="section-header">
        <h2>Recent Posts</h2>
        <a href={`${import.meta.env.BASE_URL}blog`} class="view-all">View all →</a>
      </div>
      <div class="posts-grid">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id.replace(/\.(md|mdx)$/, '')}
            tags={post.data.tags}
            heroImage={post.data.heroImage}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 4rem;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1.18;
    margin-bottom: 1.25rem;
  }

  .hero-headline em {
    color: var(--color-accent);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-ink-muted);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    letter-spacing: 0.02em;
    transition: opacity 0.15s, transform 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .recent-posts {
    padding-bottom: 5rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    margin: 0;
  }

  .view-all {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    text-decoration: none;
  }

  .view-all:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
</style>
