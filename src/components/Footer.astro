---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container-wide footer-inner">
    <p class="footer-copy">
      © {year} My Journey With
    </p>
    <nav aria-label="Footer navigation">
      <a href="/rss.xml">RSS</a>
      <a href="https://github.com/sammartinez" target="_blank" rel="noopener">GitHub</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy,
  nav {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a, .footer-copy a {
    color: var(--color-ink-muted);
    text-decoration: none;
  }

  nav a:hover, .footer-copy a:hover {
    color: var(--color-accent);
    opacity: 1;
  }
</style>
