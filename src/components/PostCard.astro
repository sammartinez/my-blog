---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, slug, tags = [], heroImage } = Astro.props;
---
<article class="post-card">
  {heroImage && (
    <a href={`/blog/${slug}`} class="card-image-link" tabindex="-1" aria-hidden="true">
      <img src={heroImage} alt="" class="card-image" loading="lazy" />
    </a>
  )}
  <div class="card-body">
    <div class="card-meta">
      <FormattedDate date={pubDate} />
    </div>
    <h2 class="card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h2>
    <p class="card-description">{description}</p>
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(tag => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    display: grid;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    transform: translateY(-2px);
  }

  .card-image-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 7;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
    border-radius: 0;
  }

  .post-card:hover .card-image {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.5rem;
  }

  .card-meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-size: 1.2rem;
    margin: 0 0 0.6rem;
  }

  .card-title a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .card-title a:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .card-description {
    color: var(--color-ink-muted);
    font-size: 0.93rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
</style>
